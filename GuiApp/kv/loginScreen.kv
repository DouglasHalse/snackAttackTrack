#:kivy 2.1.0

<LoginScreenUserWidget>:
    size_hint_x: None
    width: self.height
    first_name: "First"
    last_name: "Last"
    ClickableRoundedTwoColorGridLayout:
        id: clickableLayout
        cols: 1
        on_release: root.Clicked()
        padding: [10, 10]
        AutoScrollingLabel:
            id: first_name_label
            text: root.first_name
            color: 'black'
        AutoScrollingLabel:
            id: last_name_label
            text: root.last_name
            color: 'black'


<LoginScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas:
            Color:
                rgba: app.colors["background"]
            Rectangle:
                pos: self.pos
                size: self.size
        padding: [0, 0, 0, 20]

        # ── Top bar: title + create button ──────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: self.width / 10
            padding: 10

            NavigationBackButton:
                on_release: root.back_button_pressed()

            Label:
                text: "Select user"
                halign: 'left'
                valign: 'middle'
                text_size: self.size
                font_size: self.height * 0.5
                color: 'black'
                bold: True
                size_hint_x: 0.7
                padding: [30, 0, 0, 0]

            Widget: # Spacer

            ClickableRoundedTwoColorGridLayout:
                size_hint_x: None
                rows: 1
                width: self.height * 3
                on_release: root.createNewUserButtonClicked()
                Label:
                    text: 'Create new user'
                    bold: True
                    color: 'black'
                    font_size: self.height / 3
                    halign: 'center'
                    valign: 'middle'
        Widget:
        # ── Carousel area ───────────────────────────────────────
        FastTouchScrollView:
            id: scrollView
            size_hint_y: None
            height: 150 * self.width / 800
            size_hint_x: 1
            do_scroll_y: False
            scroll_type: ['content']
            bar_width: 0
            effect_cls: 'ScrollEffect'
            scroll_timeout: 200
            scroll_distance: 15
            GridLayout:
                id: LoginScreenUserGridLayout
                rows: 1
                spacing: 15
                padding: [0, 10]
                size_hint_x: None
                size_hint_y: 1
                width: self.minimum_width
        Widget:
        # ── Alphabet strip ──────────────────────────────────────
        AlphabetStrip:
            id: alphabetStrip
            size_hint_y: None
            height: (self.width / self.letter_count) * 1.5
            size_hint_x: 1
            on_letter_selected: root.on_alphabet_letter_selected(args[1])
