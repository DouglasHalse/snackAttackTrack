#:kivy 2.1.0

<LogLine>:
    size_hint_y: None
    height: 22
    Label:
        id: logLabel
        text: ''
        markup: False
        font_size: '13sp'
        line_height: 1.4
        shorten: False
        halign: 'left'
        valign: 'top'
        text_size: self.width, None
        padding: [8, 1]
        color: (0.05, 0.05, 0.05, 1)
